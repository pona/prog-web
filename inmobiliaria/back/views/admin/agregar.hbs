<div class="container" style="margin: 100px 0">
    <div class="row">
        <div class="col-6 offset-3 border ">
            <h4>Agregar una nueva propiedad</h4>
            <form action="/admin/tasaciones/agregar" method="post" enctype="multipart/form-data">
                <div class="mb-3 row">
                    <input type="text" class="form-control" placeholder="Título" name="title" required />
                </div>
                <div class="mb-3 row">
                    <input type="text" class="form-control" placeholder="Precio" name="price" required />
                </div>
                <div class="mb-3 row">
                    <input type="text" class="form-control" placeholder="Dirección" name="address" required />
                </div>
                <div class="mb-3 row">
                    <textarea class="form-control" placeholder="Descripción" name="description" rows="3" required></textarea>
                </div>
                <div class="form-group mb-3">
                    <label>Imagen: <input type="file" name="imagen" id="imagen" accept="image/*" /></label>
                </div>
                <button type="submit" class="btn btn-primary">Guardar</button>
            </form>
            {{#if error}}
                <h5 class="mt-3 text-danger">{{message}}</h5>
            {{/if}}
        </div>
    </div>
</div>